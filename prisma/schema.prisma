generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  role      String     @default("DOCTOR") // DOCTOR, ADMIN
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  templates Template[]
}

model DoctorProfile {
  id             String   @id @default(cuid())
  role           String   @default("doctor") // "doctor" ou "patient"
  fullName       String
  crm            String
  specialty      String
  language       String   @default("pt")
  
  // PDF Preferences
  signatureAlign String   @default("center") // "left", "center", "right"
  showLogoText   Boolean  @default(true)
  
  // AI Settings
  aiModel        String   @default("gemini-1.5-flash") // "gemini-1.5-flash", "gemini-1.5-pro"
  
  updatedAt      DateTime @updatedAt
}

model Template {
  id          String   @id @default(cuid())
  name        String   // Ex: "Ortopedia - Primeira Consulta"
  description String?
  isDefault   Boolean  @default(false)
  
  // JSONB Field to store flexible schema of the template
  // Example: [{ id: "hda", label: "História", type: "textarea" }]
  schema      String
  
  // JSONB Field to store translations for the schema labels
  // Example: { "en": { "hda": "History" }, "es": { "hda": "Historia" } }
  translations String?
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  PatientRecord PatientRecord[]
}

model PatientRecord {
  id          String   @id @default(cuid())
  patientName String
  date        DateTime @default(now())
  
  // Storing the actual anamnesis data generated by AI matching the Template schema
  // Example: { hda: "Paciente refere dor no joelho...", medicacoes: "Dipirona" }
  data        String

  templateId  String
  template    Template @relation(fields: [templateId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
